# Database Configuration
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_ROOT_PASSWORD=rootpassword123
DB_DATABASE=mlite_db
DB_USERNAME=mlite
DB_PASSWORD=mlite

# Application Configuration
# APP_PORT=8080 # gunakan jika ingin mengakses nginx dari luar container
# DB_EXTERNAL_PORT=3308 # gunakan jika ingin mengakses mysql dari luar container

# Docker Compose Profiles
# Biarkan kosong jika menggunakan SQLite. Isi dengan 'mysql_enabled' jika ingin menggunakan container MySQL
COMPOSE_PROFILES=
